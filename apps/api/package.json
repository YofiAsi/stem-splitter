{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest run --config tests/vitest.config.ts --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@stem-splitter/shared": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.1",
    "graphile-worker": "^0.16.6",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
